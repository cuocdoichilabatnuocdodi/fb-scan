# Copy this file to .env and adjust values

# Webhook server
PORT=3000
WEBHOOK_SECRET=change-this-to-random-32-char-string

# Public tunnel URL (set after starting cloudflared/ngrok)
# Example: https://random-name.trycloudflare.com
PUBLIC_WEBHOOK_URL=

# Extension path (absolute)
EXTENSION_PATH=/Users/xiaoqing/Downloads/Qing Cracked - Posts Exporter for Facebook

# Persistent profile directory (cookies, localStorage) — keeps you logged into FB
FB_SESSION_DIR=./fb-session

# Where Chromium saves downloads.
# - Leave empty → use system default (~/Downloads)
# - Set absolute path → all extension downloads go there
DOWNLOAD_ROOT=

# Extension's subfolder name inside DOWNLOAD_ROOT.
# - Empty → restore extension default "Qing Cracked | Posts Exporter for Facebook™"
# - Set custom name → patches extension constant at startup
# Output path: <DOWNLOAD_ROOT>/<OUTPUT_FOLDER_NAME>/<group>/<post>/post.json
# NOTE: same constant drives modal title in extension — both change together.
# Example: OUTPUT_FOLDER_NAME=FB Scrape Data
OUTPUT_FOLDER_NAME=

# Timing
GROUP_DELAY_MS=8000              # delay between groups (anti-FB-flag)
GROUP_TIMEOUT_MS=600000          # max 10 min per group, then skip
PAGE_LOAD_WAIT_MS=3000           # extra wait after page load (FB lazy load)

# Debug
HEADLESS=false                   # MUST be false — extension does not work headless
DEBUG=true                       # verbose console logs
